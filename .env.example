# Copy to `.env.local` in this directory and adjust values.
# Sourced automatically when you `source hub.sh` or `source env-sync.sh` (simple KEY=value lines).
# With `set -a`, variables are exported; you do not need `export` on each line.
#
# Optional: point to another file instead of ./.env.local
# SKILLS_ENV_FILE=/path/to/my-skills.env

# Parent directory containing project folders (default in script: $HOME/workspace)
ENV_SYNC_WORKSPACE=/Users/you/workspace

# Project folder name under ENV_SYNC_WORKSPACE
ENV_SYNC_PROJECT=algobot-webapp-ui

# Optional: absolute path to repo root (overrides ENV_SYNC_WORKSPACE + ENV_SYNC_PROJECT)
# ENV_SYNC_PROJECT_ROOT=/Users/you/workspace/algobot-webapp-ui

# Optional: override auto-detected skills repo root (directory that contains env-sync.sh)
# SKILLS_ROOT=/path/to/skills

# --- git-branch-workflow.sh (cleanbranches / cleanorphans)
# SKILLS_GIT_REMOTE=origin
# SKILLS_PROTECTED_BRANCHES=master main develop

# --- networking-workflow.sh (myip)
# SKILLS_MYIP_URL=http://ipecho.net/plain
